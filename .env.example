# Copy to .env for local development. Never commit real .env values.

# OpenAI
OPENAI_API_KEY=

# PostgreSQL (Neon). Hostinger only needs DATABASE_URL (pooled is fine).
# IMPORTANT on Hostinger: paste WITHOUT surrounding quotes, e.g.
#   postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Do NOT include channel_binding=require — the app strips it automatically.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Auth session secret (openssl rand -hex 32)
AUTH_SECRET=

# Local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin access (email must match a registered user)
ADMIN_EMAIL=

# Password reset email (choose Resend OR Hostinger SMTP)
EMAIL_FROM=noreply@askraghadai.com
RESEND_API_KEY=
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# Affiliate APIs (optional for Phase 1 chat; store for later automation)
ADMITAD_CLIENT_ID=
ADMITAD_CLIENT_SECRET=
ADMITAD_AUTH_HEADER=
DCM_API_KEY=
DCM_NETWORK_ID=dcm
TRAVELPAYOUTS_API_TOKEN=
